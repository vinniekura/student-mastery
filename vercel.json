{
  "crons": [
    {
      "path": "/api/send-digest",
      "schedule": "0 21 * * 1-5"
    }
  ],
  "functions": {
    "api/mock-worker.js": {
      "maxDuration": 300
    },
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "regions": ["syd1"],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
