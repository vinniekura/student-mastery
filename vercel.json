{
  "crons": [
    { "path": "/api/send-digest", "schedule": "0 21 * * 1-5" }
  ],
  "functions": {
    "api/mock-worker.js":   { "maxDuration": 300 },
    "api/ingest-doc.js":    { "maxDuration": 300 },
    "api/docs.js":          { "maxDuration": 60 },
    "api/generate-mock.js": { "maxDuration": 60 },
    "api/papers.js":        { "maxDuration": 60 },
    "api/profile.js":       { "maxDuration": 60 },
    "api/quick-quiz.js":    { "maxDuration": 60 },
    "api/send-digest.js":   { "maxDuration": 60 },
    "api/subjects.js":      { "maxDuration": 60 }
  },
  "regions": ["syd1"],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
    { "source": "/api/mock-section", "destination": "/api/mock-section.js" },
    { "source": "/api/mock-assemble", "destination": "/api/mock-assemble.js" },
  ]
}
